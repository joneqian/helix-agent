# infra/.env — local dev / dogfood overrides for docker-compose.yml
#
# Copy to infra/.env (git-ignored) and fill in real values:
#     cp infra/.env.example infra/.env
#
# docker compose auto-loads infra/.env when run from this directory, so these
# values flow into the ${VAR:-default} refs in docker-compose.yml without any
# export. NEVER commit infra/.env — it holds secrets.

# ── 机密存储后端(Stream Q)──
# 加密金库后端选择:
#   local_dev     文件后端,key 从 infra/dev-keys/*.local 读,不支持 web 粘贴(默认)
#   sql_encrypted 落地加密金库,在 /settings/platform 粘真值,AES-256-GCM 进
#                 encrypted_secret 表 —— web E2E 用这个
#   aliyun_kms    阿里云 KMS(未实现,占位)
HELIX_AGENT_SECRET_STORE_BACKEND=sql_encrypted

# sql_encrypted 的 KEK(根密钥):base64 编码的 32 字节。生成:openssl rand -base64 32
# 警告:它加密 encrypted_secret 每一行,丢失/更换会让所有已存 key 永久无法解密。
# 模板留空,真值只写进 infra/.env。
HELIX_AGENT_SECRET_ENCRYPTION_KEY=


# ── 账号 / 登录(Stream ACCT / R)──
# true=用真 Keycloak 建账号(员工可登录);false=进程内 Fake(无需起 Keycloak)
HELIX_AGENT_KEYCLOAK_ENABLED=true

# 该邮箱首次登录自动升为 system_admin(平台管理员);留空=关
HELIX_AGENT_BOOTSTRAP_ADMIN_EMAIL=

# 首装向导(/setup)一次性 token,门控未鉴权的初始化端点
HELIX_AGENT_SETUP_TOKEN=


# ── 可观测:自建 Langfuse(Stream OBS)──
# 两组前缀各有用途,别当重复删:
#   HELIX_AGENT_LANGFUSE_*  控制面 app 推 trace 用
#   HELIX_LANGFUSE_*        Langfuse 容器自身 + 初始化账号用
HELIX_AGENT_LANGFUSE_HOST=
HELIX_LANGFUSE_PUBLIC_KEY=
HELIX_LANGFUSE_SECRET_KEY=
HELIX_AGENT_LANGFUSE_PUBLIC_KEY=
HELIX_AGENT_LANGFUSE_SECRET_KEY=
HELIX_LANGFUSE_INIT_EMAIL=
HELIX_LANGFUSE_INIT_PASSWORD=
# PII 脱敏默认 true(fail-safe);仅调试看原始 prompt 才设 false
# HELIX_AGENT_LANGFUSE_PII_MASKING_ENABLED=true


# ── 评估 worker(11.4/11.5)──
# 开后排空已入队的 eval run(trace / adversarial 套件);
# EVAL_AGENT_MODEL 必须是本租户平台配了凭证的 provider/model。
HELIX_AGENT_ENABLE_EVAL_WORKER=false
HELIX_AGENT_EVAL_WORKER_INTERVAL_S=300
HELIX_AGENT_EVAL_AGENT_PROVIDER=anthropic
HELIX_AGENT_EVAL_AGENT_MODEL=claude-sonnet-4-6


# ── skill-evolution 飞轮(4.4)──
# 从真实轨迹 + 反馈自动蒸馏 / 验证 / 升级 skill(可选,E2E 用),默认 OFF。
# 开后 SkillEvolutionWorker 排空 curation candidate:aux LLM 蒸 DRAFT skill →
# 真 graph replay(有 skill vs 无 skill)→ grounding 判决 → 自动升级 / 留审。
# AUX_PROVIDER 必须是本租户平台配了凭证的 provider;interval 设短为 E2E 快跑。
HELIX_AGENT_ENABLE_SKILL_EVOLUTION_WORKER=true
HELIX_AGENT_SKILL_EVOLUTION_WORKER_INTERVAL_S=15
HELIX_AGENT_CURATION_WORKER_INTERVAL_S=15
HELIX_AGENT_MEMORY_CONSOLIDATOR_DEFAULT_AUX_PROVIDER=deepseek
HELIX_AGENT_MEMORY_CONSOLIDATOR_DEFAULT_AUX_MODEL=deepseek-v4-pro


# ── MCP per-user OAuth 连接器(Stream MCP-OAUTH)──
# 回调地址:必须指向客户端的回调页(admin-ui 或独立客户端),不是后端端点;
# 留空 → initiate 端点返 503。这是全局默认,也是未传 redirect_uri 时的兜底。
HELIX_AGENT_MCP_OAUTH_REDIRECT_URI=http://localhost:5173/settings/mcp-oauth/callback

# 目录 seed 模板(镜像内 /app/configs):默认空数组,不预置连接器 —— 连接器经
# admin-ui 目录手工配。仅当你往 seed 文件追加条目预置时才需指向它;留空 → 不 seed。
HELIX_AGENT_MCP_CATALOG_SEED_FILE=configs/mcp-catalog-seed.json

# 独立(非 loopback)客户端的 redirect 白名单。JSON 数组(pydantic 按 JSON 解码
# list 型 env,同 OIDC_AUDIENCE);默认 [] 空数组——空字符串会 JSON 解码失败、启动崩。
# loopback(127.0.0.1 / localhost,任意端口)默认放行,无需列入。
# HELIX_AGENT_MCP_OAUTH_REDIRECT_ALLOWLIST=["https://client.example.com/callback"]
