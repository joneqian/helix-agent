# infra/.env — local dev / dogfood overrides for docker-compose.yml
#
# Copy to infra/.env (git-ignored) and fill in real values:
#     cp infra/.env.example infra/.env
#
# docker compose auto-loads infra/.env when run from this directory, so these
# values flow into the ${VAR:-default} refs in docker-compose.yml without any
# export. NEVER commit infra/.env — it holds secrets.

# ── Secret store backend (Stream Q) ──
#   local_dev     file backend; keys from infra/dev-keys/*.local, no web paste (default)
#   sql_encrypted encrypted-at-rest vault; paste real key in /settings/platform,
#                 AES-256-GCM into encrypted_secret table — use for web E2E
#   aliyun_kms    Aliyun KMS (not implemented yet — stub)
HELIX_AGENT_SECRET_STORE_BACKEND=sql_encrypted

# KEK for sql_encrypted: base64-encoded 32 bytes. Generate: openssl rand -base64 32
# WARNING: encrypts every encrypted_secret row; losing/changing it makes all
# stored keys permanently undecryptable. Leave blank here; set real value in .env.
HELIX_AGENT_SECRET_ENCRYPTION_KEY=


# 用真 Keycloak 建账号(员工能登录);false=进程内 Fake
HELIX_AGENT_KEYCLOAK_ENABLED=true

# 邮箱首登自动升 system_admin
HELIX_AGENT_BOOTSTRAP_ADMIN_EMAIL=


# 沙箱镜像
HELIX_SANDBOX_IMAGE_OFFICE=your-registry.com/helix-agent/helix-sandbox-office:latest

# 自建 Langfuse 实例
HELIX_AGENT_LANGFUSE_HOST=
HELIX_LANGFUSE_PUBLIC_KEY=
HELIX_LANGFUSE_SECRET_KEY=
HELIX_AGENT_LANGFUSE_PUBLIC_KEY=
HELIX_AGENT_LANGFUSE_SECRET_KEY=
HELIX_LANGFUSE_INIT_EMAIL=
HELIX_LANGFUSE_INIT_PASSWORD=
# HELIX_AGENT_LANGFUSE_PII_MASKING_ENABLED=true   # 默认 true,关脱敏才设 false

# 启用评估 worker
HELIX_AGENT_ENABLE_EVAL_WORKER=false
HELIX_AGENT_EVAL_WORKER_INTERVAL_S=300
HELIX_AGENT_EVAL_AGENT_PROVIDER=anthropic
HELIX_AGENT_EVAL_AGENT_MODEL=claude-sonnet-4-6
