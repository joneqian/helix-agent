    "@rjsf/validator-ajv8": "^5.24.13",
    "antd": "^5.23.0",
    "axios": "^1.7.9",
    "dayjs": "^1.11.20",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.469.0",
    "oidc-client-ts": "^3.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
