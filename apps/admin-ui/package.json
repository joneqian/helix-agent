{
  "name": "@helix-agent/admin-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "helix Admin UI — Stream H.1b production scaffold. Operator-facing SPA for platform / tenant administrators. See memory:admin-ui-design-baseline + memory:cross-tenant-admin.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "storybook": "storybook dev -p 6006 --no-open --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry"
  },
