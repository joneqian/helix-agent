{
  "uid": "helix-orchestrator",
  "title": "Helix \u2014 Orchestrator",
  "tags": [
    "helix",
    "g.7"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "Orchestrator \u2014 session / LLM / tool metrics. TTFT and durable-resume are emitted by the SSE worker; recording rules in `tools/observability/rules/sli.yml` back SLOs #3 / #5."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "LLM tokens / s (by direction)",
      "datasource": {
        "type": "prometheus",
        "uid": "helix-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "helix-prometheus"
          },
          "expr": "sum by (direction) (rate(helix_llm_tokens_total[5m]))",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Session TTFT P95",
      "datasource": {
        "type": "prometheus",
        "uid": "helix-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "helix-prometheus"
          },
          "expr": "helix:sli:session_ttft:p95_5m",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tool-call duration P95 (by tool_type)",
      "datasource": {
        "type": "prometheus",
        "uid": "helix-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "helix-prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, tool_type) (rate(helix_tool_call_duration_seconds_bucket[5m])))",
          "legendFormat": "{{tool_type}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Durable resume P95 (SLI, 5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "helix-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "helix-prometheus"
          },
          "expr": "helix:sli:durable_resume:p95_5m",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Session end-to-end P95 (SLI, 5m, outcome=success)",
      "datasource": {
        "type": "prometheus",
        "uid": "helix-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "helix-prometheus"
          },
          "expr": "helix:sli:session_duration:p95_5m",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
