{
  "uid": "helix-overview",
  "title": "Helix — Overview",
  "tags": ["helix", "g.7"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Control-plane availability (SLI, 5m)",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "helix:sli:control_plane_availability:ratio5m"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate (QPS)",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "sum(rate(helix_control_plane_http_requests_total[5m]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx error rate",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "sum(rate(helix_control_plane_http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request latency P99 (SLI, 5m)",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "helix:sli:control_plane_http_latency:p99_5m",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Session TTFT P95 (SLI, 5m)",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "helix:sli:session_ttft:p95_5m",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Session end-to-end P95 (SLI, 5m)",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "helix:sli:session_duration:p95_5m",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SSE stream-stale rate",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "sum(rate(helix_llm_stream_stale_total[5m])) / clamp_min(sum(rate(helix_llm_tokens_total[5m])), 1)",
          "legendFormat": "stale ratio"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Sandbox cold-start P95 (SLI, 5m)",
      "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "helix:sli:sandbox_cold_start:p95_5m",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
